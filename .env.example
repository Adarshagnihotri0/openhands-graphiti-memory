# Graphiti Memory Configuration Example
# Copy this to .env and fill in your values

# ========================================
# Database Configuration
# ========================================

# Graph database provider: "neo4j" or "falkordb"
GRAPHITI_DATABASE_PROVIDER=neo4j

# Database connection URI
GRAPHITI_DATABASE_URI=bolt://localhost:7687

# Database credentials
GRAPHITI_DATABASE_USER=neo4j
GRAPHITI_DATABASE_PASSWORD=your_password_here

# Database name
GRAPHITI_DATABASE_NAME=openhands_memory

# ========================================
# LLM Configuration
# ========================================

# LLM provider: "openai", "anthropic", or "azure_openai"
GRAPHITI_LLM_PROVIDER=openai

# Model name
GRAPHITI_LLM_MODEL=gpt-4o-mini

# LLM temperature (0.0 - 2.0)
GRAPHITI_LLM_TEMPERATURE=0.0

# API key for LLM
GRAPHITI_LLM_API_KEY=your_openai_api_key_here

# ========================================
# Embedding Configuration
# ========================================

# Embedder provider: "openai", "voyage", or "sentence_transformers"
GRAPHITI_EMBEDDER_PROVIDER=openai

# Embedding model
GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small

# ========================================
# Memory Settings
# ========================================

# Group ID for this installation
GRAPHITI_GROUP_ID=openhands_main

# Repository scope (auto-detected, can override)
GRAPHITI_REPOSITORY_SCOPE=default

# Branch scope (auto-detected, can override)
GRAPHITI_BRANCH_SCOPE=main

# ========================================
# Retrieval Settings
# ========================================

# Maximum memories to retrieve per query
GRAPHITI_RETRIEVAL_LIMIT=10

# Minimum confidence for retrieval (0.0 - 1.0)
GRAPHITI_CONFIDENCE_THRESHOLD=0.7

# Weight for semantic similarity (0.0 - 1.0)
GRAPHITI_SEMANTIC_WEIGHT=0.6

# Weight for graph traversal (0.0 - 1.0)
GRAPHITI_GRAPH_WEIGHT=0.4

# ========================================
# Performance Settings
# ========================================

# Concurrent episode processing limit
GRAPHITI_SEMAPHORE_LIMIT=10

# Maximum retry attempts
GRAPHITI_MAX_RETRIES=3

# Delay between retries (seconds)
GRAPHITI_RETRY_DELAY=1.0

# Operation timeout (seconds)
GRAPHITI_TIMEOUT_SECONDS=30.0

# ========================================
# Memory Lifecycle Settings
# ========================================

# Days before memory expiration
GRAPHITI_MEMORY_EXPIRATION_DAYS=365

# Update similar memories instead of creating duplicates
GRAPHITI_AUTO_UPDATE_SIMILAR=true

# Minimum confidence to store a memory
GRAPHITI_MIN_CONFIDENCE_TO_STORE=0.5

# ========================================
# Observability Settings
# ========================================

# Log level: "DEBUG", "INFO", "WARNING", "ERROR"
GRAPHITI_LOG_LEVEL=INFO

# Enable metrics collection
GRAPHITI_ENABLE_METRICS=true

# Enable distributed tracing
GRAPHITI_ENABLE_TRACING=false

# ========================================
# Failure Handling
# ========================================

# Continue if Graphiti is unavailable
GRAPHITI_FAIL_SILENTLY=true

# Use local cache if Graphiti fails
GRAPHITI_FALLBACK_TO_CACHE=true

# Cache TTL in seconds
GRAPHITI_CACHE_TTL_SECONDS=3600
